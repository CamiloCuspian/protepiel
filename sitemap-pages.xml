---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% assign pages = site.pages | where_exp: "p", "p.sitemap != false" %}
  {% for page in pages %}
  {% unless page.url contains '404' or page.url contains 'feed' or page.url contains 'sitemap' or page.url contains 'robots' %}
  <url>
    <loc>{{ site.url }}{{ page.url | replace:'index.html','' }}</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>{% if page.url == '/' %}1.0{% elsif page.url contains 'crema-urea' %}0.9{% else %}0.8{% endif %}</priority>
  </url>
  {% endunless %}
  {% endfor %}
</urlset>
